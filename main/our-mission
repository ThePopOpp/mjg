<!-- ── Dynamic Impact Score ──────────────────────────────────── -->
<script>
(function() {
  var GOAL = 1000000000;
  var API  = 'https://michaeljgauthier.com/wp-json/blueprint/v1/impact-score';

  function fmtDollars(n) {
    return '$' + Number(n).toLocaleString('en-US');
  }

  function fmtDate(raw) {
    if (!raw) return '';
    // Jet Engine stores datetime as a Unix timestamp (integer string)
    var ts = parseInt(raw, 10);
    var d;
    if (!isNaN(ts) && ts > 100000000) {
      d = new Date(ts * 1000);
    } else {
      // Fallback: try parsing as a date string (e.g. "2026-04-10 00:00:00")
      d = new Date(raw.replace(' ', 'T'));
    }
    if (isNaN(d.getTime())) return raw;
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  function applyScore(score, dateRaw) {
    var pct     = Math.min((score / GOAL) * 100, 100);
    var pctText = (pct % 1 === 0 ? pct.toFixed(0) : pct.toFixed(1)) + '% of goal';

    var valEl  = document.getElementById('impact-score-val');
    var dateEl = document.getElementById('impact-score-date');
    var pctEl  = document.getElementById('impact-score-pct');
    var fillEl = document.getElementById('impact-score-fill');

    if (valEl)  valEl.textContent  = fmtDollars(score);
    if (dateEl) dateEl.textContent = 'As of ' + fmtDate(dateRaw);
    if (pctEl)  pctEl.textContent  = pctText;
    if (fillEl) {
      // Let the page paint first so the CSS transition fires
      requestAnimationFrame(function() {
        fillEl.style.width = pct.toFixed(3) + '%';
      });
    }
  }

  fetch(API, { cache: 'no-cache' })
    .then(function(res) { return res.ok ? res.json() : Promise.reject(res.status); })
    .then(function(data) {
      var score = parseInt(String(data.impact_score).replace(/[^0-9]/g, ''), 10);
      if (score > 0) applyScore(score, data.impact_score_date);
    })
    .catch(function() { /* keep hardcoded fallback values */ });
})();
</script>
