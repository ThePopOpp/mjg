  };
  if (window.grecaptcha) { grecaptcha.ready(function() { grecaptcha.execute(JM_RECAPTCHA_KEY, {action:'journey_signup'}).then(doSubmit).catch(function(){ doSubmit(''); }); }); } else { doSubmit(''); }
