    data.source = 'Join The Journey Modal';
    var ci = document.getElementById('jm-churchInput'), oi = document.getElementById('jm-otherInput');
    if (ci.name) data.church_name = ci.value;
    if (oi.name) data.other_source = oi.value;
    fetch(FLUENT_CRM_URL, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:new URLSearchParams(data) })
